# Copy this file to .env and fill in every value before starting the server.
# Never commit .env to git.

SECRET_KEY=replace-with-a-long-random-string
DEBUG=False

# Comma-separated — include your domain and www variant
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# Comma-separated — must start with https://
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

DB_NAME=ferite_steel_db
DB_USER=ferite_user
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432

TOGETHER_API_KEY=replace-with-together-api-key

# Leave these as-is — email sending is handled per-team via TeamEmailConfig in admin
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
